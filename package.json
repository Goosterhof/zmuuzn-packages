{
  "name": "@goosterhof/lab-nav",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/lab-nav.js"
    },
    "./style.css": "./dist/lab-nav.css"
  },
  "main": "./dist/lab-nav.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "vite build",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint -c oxlintrc.json src/ tests/ --deny-warnings && ! grep -rn 'withDefaults\\|const props' src/components/",
    "format": "oxfmt --write src/ tests/",
    "format:check": "oxfmt --check src/ tests/",
    "check": "npm run type-check && npm run lint && npm run format:check && npm run test"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^18.0.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "^5.9.3",
    "unocss": "^66.6.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4",
    "vue-tsc": "^3.2.4"
  }
}
